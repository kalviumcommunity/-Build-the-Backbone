{
  "name": "quickbite-performance-lab",
  "version": "1.0.0",
  "description": "QuickBite: A Food Delivery API for Performance Engineering Challenges",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "psql \"%DATABASE_URL%\" -f migrations/001_create_tables.sql",
  "seed": "psql \"%DATABASE_URL%\" -f migrations/002_seed_data.sql",
    "test:load": "artillery run artillery-baseline.yml"
  },
  "keywords": [
    "performance",
    "api",
    "node",
    "postgres",
    "n+1",
    "profiling",
    "artillery"
  ],
  "author": "Antigravity Senior Backend Engineer",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "bullmq": "^5.35.0",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "artillery": "^2.0.0-39",
    "nodemon": "^3.0.1"
  }
}
